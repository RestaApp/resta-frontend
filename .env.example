# Пример переменных окружения фронтенда (Telegram Mini App).
# Скопируйте в .env и заполните. Клиентские переменные ОБЯЗАНЫ иметь префикс VITE_.
# ⚠️ Не храните здесь реальных секретов и реальных Telegram initData.

# Базовый URL бэкенда (Rails API). Обязательная.
VITE_API_URL=https://resta-backend.example.com

# Гейт проактивного UI монетизации (PRO-карточка, UsageIndicator).
# 'true' — включает; поток покупок по слотам реагирует на реальный 402 независимо от флага.
VITE_MONETIZATION=false

# Только для локальной разработки (import.meta.env.DEV): подменяет Telegram initData,
# чтобы запускать приложение вне Telegram. В production-бандл не попадает.
# Сгенерируйте синтетический payload — НЕ используйте данные реальных пользователей.
# VITE_MOCK_INIT_DATA=

# Версия клиента для заголовка x-client-version. Опциональна:
# при сборке подставляется автоматически (см. vite.config.ts), переопределяет это значение.
# VITE_APP_VERSION=
